SHELL		= /bin/bash

# ====== CONFIG ======
NAME		= animal
CXX			= c++
CXXFLAGS	= -Wall -Wextra -Werror -std=c++98 -g
RM			= rm -rf

SRC			= $(wildcard *.cpp) $(wildcard AAnimal/*.cpp) $(wildcard WrongAnimal/*.cpp) $(wildcard Brain/*.cpp) $(wildcard AMateria/*.cpp)
OBJ_DIR		= .obj
OBJ			= $(SRC:%.cpp=$(OBJ_DIR)/%.o)

TOTAL_FILES	:= $(words $(SRC))
COUNT_FILE	:= .make_count

# ====== COULEURS & VISUELS ======
DEF_COLOR	= \033[0;39m
GREEN		= \033[1;32m
CYAN		= \033[1;36m
DIM			= \033[2m
YELLOW		= \033[0;33m

.DEFAULT_GOAL := start

# ====== RГҲGLES ======

start:
	@clear
	@echo 0 > $(COUNT_FILE)
	@printf "$(DIM)>>> Preparation...$(DEF_COLOR)"
	@frames=("в Ӣ " "в ҷ " "в № " "в ё " "в ј " "в ҙ " "в Ұ " "в § " "в Ү " "в Ҹ "); \
	for i in {1..10}; do \
		printf "\r$(DIM)>>> Preparation... $(CYAN)$${frames[$$i]}$(DEF_COLOR)"; \
		sleep 0.04; \
	done
	@printf "\r$(GREEN)[в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ] вң“$(DEF_COLOR) Ready to compile\n\n"
	@printf "$(DIM)>>> Compiling $(NAME) (std=c++98)...$(DEF_COLOR)\n    "
	@$(MAKE) --no-print-directory all

all: $(NAME)

$(NAME): $(OBJ)
	@printf " $(GREEN)вң“$(DEF_COLOR)\n\n"
	@$(CXX) $(CXXFLAGS) $(OBJ) -o $(NAME)
	@printf "$(GREEN)"
	@echo "    в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
	@echo "    в”Ӯ                                        в”Ӯ"
	@echo "    в”Ӯ         [ OK ] C++ Compilation         в”Ӯ"
	@echo "    в”Ӯ                                        в”Ӯ"
	@echo "    в”Ӯ           Executable: $(NAME)           в”Ӯ"
	@echo "    в”Ӯ                                        в”Ӯ"
	@echo "    в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"
	@echo ""
	@printf "$(DEF_COLOR)"

$(OBJ_DIR)/%.o: %.cpp
	@mkdir -p $(dir $@)
	@$(eval CURRENT_COUNT=$(shell if [ -f $(COUNT_FILE) ]; then cat $(COUNT_FILE); else echo 0; fi))
	@$(eval CURRENT_COUNT=$(shell echo $$(($(CURRENT_COUNT) + 1))))
	@echo $(CURRENT_COUNT) > $(COUNT_FILE)
	@$(eval PERCENT=$(shell echo $$(($(CURRENT_COUNT) * 100 / $(TOTAL_FILES)))))
	@printf "\r$(GREEN)Compiling...[%d/%d] (%d%%)$(DEF_COLOR)" $(CURRENT_COUNT) $(TOTAL_FILES) $(PERCENT)
	@$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	@printf "$(DIM)>>> Cleaning objects...$(DEF_COLOR)\n"
	@$(RM) $(OBJ_DIR)
	@$(RM) $(COUNT_FILE)
	@printf "    $(GREEN)[в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ] вң“$(DEF_COLOR) Done\n"

fclean: clean
	@printf "$(DIM)>>> Removing executable...$(DEF_COLOR)\n"
	@$(RM) $(NAME)
	@printf "    $(GREEN)[в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ] вң“$(DEF_COLOR) Done\n\n"
	@printf "$(YELLOW)    FULL CLEAN COMPLETED$(DEF_COLOR)\n"

re: fclean start

.PHONY: start all clean fclean re